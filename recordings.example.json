{
  "guide_url": "https://animenosekai.github.io/japanterebi-xmltv/guide.xml",
  "guide_cache": "guide.xml",
  "guide_cache_max_age_seconds": 21600,
  "timezone": "Asia/Tokyo",
  "lookahead_days": 14,
  "matching_window_hours": 12,
  "shift_threshold_minutes": 0,
  "notify_missing": false,
  "notify_recovery": true,
  "recordings": [
    {
      "id": "daily-example",
      "title": "Example Daily Program",
      "title_match": "exact",
      "channel": "ExampleChannel.jp",
      "recurrence": "daily",
      "time": "19:00"
    },
    {
      "id": "weekly-friday-example",
      "title": "Example Weekly Anime",
      "title_match": "contains",
      "channel": "TokyoMX.jp",
      "recurrence": "weekly",
      "weekday": "fri",
      "time": "23:30"
    },
    {
      "id": "weekly-mon-thu-example",
      "title": "Example Twice Weekly Program",
      "title_match": "exact",
      "channels": [
        "BS11.jp",
        "TokyoMX.jp"
      ],
      "recurrence": "weekly",
      "weekdays": [
        "mon",
        "thu"
      ],
      "time": "22:00"
    }
  ]
}
